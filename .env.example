# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret  (or: openssl rand -base64 33)
AUTH_SECRET=

# GitHub OAuth App credentials (one app per environment — see docs/auth-plan.md)
# Dev app callback:  http://localhost:3000/api/auth/callback/github
# Prod app callback: https://<your-domain>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitHub token — increases API rate limit from 60 to 5000 req/hr. Optional for local dev.
# When a user is logged in, their OAuth token is used instead of this.
GITHUB_TOKEN=

# OpenAI API key — enables LLM enrichment pass. Gracefully skipped if absent.
OPENAI_API_KEY=

# --- Graph store (deploy only) ---
# When these are set, Cascade uses a shared Upstash Redis (Vercel KV) store so graphs
# survive across serverless requests. Leave BLANK locally to use the on-disk file store.
# Provisioned automatically when you add the Upstash integration in the Vercel dashboard.
KV_REST_API_URL=
KV_REST_API_TOKEN=
