# GitHub token — increases API rate limit from 60 to 5000 req/hr. Optional for local dev.
GITHUB_TOKEN=

# OpenAI API key — enables LLM enrichment pass. Gracefully skipped if absent.
OPENAI_API_KEY=

# --- Graph store (deploy only) ---
# When these are set, Cascade uses a shared Upstash Redis (Vercel KV) store so graphs
# survive across serverless requests. Leave BLANK locally to use the on-disk file store.
# Provisioned automatically when you add the Upstash integration in the Vercel dashboard.
KV_REST_API_URL=
KV_REST_API_TOKEN=
