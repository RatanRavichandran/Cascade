# Copy to .env and fill in values.
# .env is gitignored — never commit real secrets.

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model for the Facilitator (benefits from stronger reasoning to classify/synthesize)
CASCADE_FACILITATOR_MODEL=gpt-4o

# Model for Ripple Analyst and Test Debugger (cheaper is fine for focused analysis)
CASCADE_SPECIALIST_MODEL=gpt-4o-mini

# Fallback if per-role vars above are unset
CASCADE_AGENT_MODEL=gpt-4o-mini

# ── Cascade app ───────────────────────────────────────────────────────────────
# Base URL of the deployed Cascade Next.js app on Vercel.
CASCADE_API_BASE=https://your-app.vercel.app

# OPTIONAL — legacy single-repo shortcut. If set, the agent process pre-warms the
# context cache at startup for this repo. Not required since T2: context is resolved
# lazily per-room from the [repoId:...] seed tag. Use seed_room.py to pass the repoId.
# CASCADE_REPO_ID=owner-repo

# ── Band platform ─────────────────────────────────────────────────────────────
# Room creation + seeding uses the Band AGENT API (the Human API is Enterprise-only
# and 403s on Pro — see docs/t1-findings.md). The Orchestrator agent's api_key is
# read from agent_config.yaml by the T3 CLI, so no separate env var is needed locally.
# For the Vercel POST /api/ripple route (T4), set the same key as a server-only env var:
#   BAND_ORCHESTRATOR_KEY=<orchestrator agent api_key>
# Always pin the production host explicitly — the SDK defaults to a DEV URL:
#   base_url = https://app.band.ai

# band-sdk 1.0.0 defaults to app.band.ai — only set these for a staging instance.
# BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# BAND_REST_URL=https://app.band.ai

# ── Health server ─────────────────────────────────────────────────────────────
# Render injects $PORT automatically. Override only for local testing.
# PORT=10000
