# Copy to .env and fill in values.
# .env is gitignored — never commit real secrets.

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model for the Facilitator (benefits from stronger reasoning to classify/synthesize)
CASCADE_FACILITATOR_MODEL=gpt-4o

# Model for Ripple Analyst and Test Debugger (cheaper is fine for focused analysis)
CASCADE_SPECIALIST_MODEL=gpt-4o-mini

# Fallback if per-role vars above are unset
CASCADE_AGENT_MODEL=gpt-4o-mini

# ── Cascade app ───────────────────────────────────────────────────────────────
# Base URL of the deployed Cascade Next.js app on Vercel.
CASCADE_API_BASE=https://your-app.vercel.app

# Repository ID to analyze — format: <owner>-<repo>, e.g. docker-getting-started-todo-app
CASCADE_REPO_ID=owner-repo

# ── Band platform (optional overrides) ───────────────────────────────────────
# band-sdk 1.0.0 defaults to app.band.ai — only set these for a staging instance.
# BAND_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# BAND_REST_URL=https://app.band.ai

# ── Health server ─────────────────────────────────────────────────────────────
# Render injects $PORT automatically. Override only for local testing.
# PORT=10000
